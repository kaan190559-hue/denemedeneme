MOON_SESSION_ID=buraya_session_id
MOON_CSRF_TOKEN=buraya_csrf_token
# Alternatif: DevTools Network cookie satırını komple buraya koy.
# MOON_COOKIE_HEADER=session_id=...; csrf_token=...; __cf_bm=...
TELEGRAM_BOT_TOKEN=buraya_botfather_token
DASHBOARD_STATE_URL=https://render-panel-linkin.onrender.com
DATABASE_URL=postgresql://kullanici:sifre@host:5432/veritabani
PORT=8787

# Excel / OneDrive merkezi kayıt. 0 iken mevcut sistem aynen çalışır.
EXCEL_CENTER_ENABLED=0
# 1 yaparsan panel/bot önce Excel'den okumaya çalışır, okuyamazsa mevcut kayda düşer.
EXCEL_CENTER_PRIMARY=0
MS_TENANT_ID=consumers
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=
MS_GRAPH_SCOPES=offline_access Files.ReadWrite User.Read
EXCEL_WORKBOOK_SHARE_URL=
# Paylaşım linki yerine drive/item kullanmak istersen:
EXCEL_WORKBOOK_DRIVE_ID=
EXCEL_WORKBOOK_ITEM_ID=
EXCEL_SYNC_MIN_MS=5000

# Azure'suz OneDrive klasör merkezi. OneDrive masaüstü senkron klasörüne yazar.
ONEDRIVE_CENTER_ENABLED=0
ONEDRIVE_CENTER_PRIMARY=0
ONEDRIVE_CENTER_DIR=C:\Users\user\OneDrive\BozokMerkez
ONEDRIVE_SYNC_MIN_MS=500

# Tampermonkey yerine Moon oturum botu. Gizli değerleri repoya yazma.
MOON_AUTOMATION_ENABLED=0
MOON_USERNAME=
MOON_PASSWORD=
MOON_TOTP_SECRET=
# Secret geçersizse geçici yedek 2FA kodu.
MOON_BACKUP_CODE=
MOON_TOTP_ALGORITHM=sha1
MOON_TOTP_DIGITS=6
MOON_TOTP_STEP_SECONDS=30
MOON_AUTOMATION_INTERVAL_MS=1000
MOON_FETCH_TIMEOUT_MS=10000
MOON_TRANSACTIONS_LIMIT=500
MOON_TRANSACTIONS_MAX_PAGES=20
MOON_DEPOSIT_APPROVED_STATUSES=approved,completed,onaylandi,onaylandı,success,succeeded
MOON_BROWSER_FETCH_FALLBACK=1
MOON_MAX_CONSECUTIVE_ERRORS=3
MOON_STALE_RESTART_MS=15000
MOON_MIN_RESTART_GAP_MS=10000
MOON_PAGE_HEARTBEAT_MS=30000
MOON_HEADLESS=1
MOON_AUTH_DIR=moon-auth-storage
# Windows local test için boş bırakılırsa Edge/Chrome otomatik aranır.
MOON_BROWSER_EXECUTABLE=
MOON_DEVICE_NAME=moon-playwright-bot
